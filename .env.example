# Application
APP_NAME=credit-risk-altdata
APP_ENV=dev
LOG_LEVEL=INFO

# Local Ollama runtime
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CODE_MODEL=qwen2.5-coder:7b
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=30

# Phase 7 local LLM report generation
LLM_REPORTS_MODEL_NAME=qwen2.5:7b
LLM_REPORTS_REPORT_TYPE=all
LLM_REPORTS_METHOD_SOURCE=auto
LLM_REPORTS_MAX_CASES=50
LLM_REPORTS_TIMEOUT_SECONDS=30
LLM_REPORTS_RETRIES=2
LLM_REPORTS_ENABLE_FALLBACK=true
LLM_REPORTS_OUTPUT_DIR=artifacts/llm_reports

# Kaggle Home Credit data source
KAGGLE_DATASET=home-credit-default-risk
KAGGLE_USERNAME=
KAGGLE_KEY=

# Core project paths
DATA_DIR=data
ARTIFACTS_DIR=artifacts
RANDOM_SEED=42

# Modeling and selection
MODELING_FOLDS=5
MODELING_THRESHOLD=0.5
MODELING_PRIMARY_METRIC=roc_auc
MODELING_TUNING_TRIALS=20
MODELING_CALIBRATION_STRATEGY=all
MODELING_THRESHOLD_GRID_MIN=0.1
MODELING_THRESHOLD_GRID_MAX=0.9
MODELING_THRESHOLD_GRID_STEP=0.05
MODELING_FINAL_MODEL_PATH=artifacts/modeling/models/final_production_model.joblib

# Explainability
EXPLAINABILITY_INPUT_PATH=artifacts/modeling/predictions/tuned_oof_predictions.parquet
EXPLAINABILITY_SAMPLE_SIZE=1000
EXPLAINABILITY_TOP_K=10
EXPLAINABILITY_RANDOM_SEED=42
EXPLAINABILITY_TRUE_POSITIVE_EXAMPLES=3
EXPLAINABILITY_TRUE_NEGATIVE_EXAMPLES=3
EXPLAINABILITY_FALSE_POSITIVE_EXAMPLES=3
EXPLAINABILITY_FALSE_NEGATIVE_EXAMPLES=3
EXPLAINABILITY_BORDERLINE_EXAMPLES=3
